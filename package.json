{
  "name": "telegramsh",
  "version": "1.0.3",
  "description": "Минималистичное приложение для Telegram",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "Sirik Condition Company",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.sirik.telegram-desktop",
    "productName": "TelegramSH",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.ico"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico",
      "publisherName": "Sirik Condition Company"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
